{
  "name": "nestjs-auth-rbac-starter",
  "version": "0.0.1",
  "description": "NestJS starter with RBAC authentication",
  "author": "Emmanuel Mura",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:cov": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:debug": "cross-env NODE_OPTIONS=--experimental-vm-modules bun --inspect-brk node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@nestjs-modules/mailer": "^2.3.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "bfj": "^9.1.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.9.0",
    "config": "^4.4.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "envalid": "^8.1.1",
    "fastify-swagger": "^5.2.0",
    "google-auth-library": "^10.6.2",
    "handlebars": "^4.7.8",
    "ky": "^2.0.0",
    "moment": "^2.30.1",
    "nanoid": "^3.3.11",
    "nest-winston": "^1.10.2",
    "nestjs-real-ip": "^3.0.1",
    "nodemailer": "^8.0.3",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-strategy": "^1.0.0",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "@types/bcrypt": "^6.0.0",
    "@types/config": "^4.4.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/nodemailer-smtp-transport": "^2.7.8",
    "@types/passport": "^1.0.17",
    "@types/passport-strategy": "^0.2.38",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "jest": {
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid|ky)/)"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
